---
import Base from '../layouts/Base.astro';
import HeroNetwork from '../components/HeroNetwork.astro';

const patterns = [
  {
    href: '/patterns/ai-disclosure-badge',
    article: 'Article 50(1)',
    name: 'AI Disclosure',
    accent: 'Badge',
    blurb: 'Tell people they are interacting with an AI system — clearly and distinguishably.',
  },
  {
    href: '/patterns/ai-content-label',
    article: 'Article 50(4)',
    name: 'AI Content',
    accent: 'Label',
    blurb: 'Mark generated or manipulated content — including deepfakes — for people and machines.',
  },
  {
    href: '/patterns/emotion-recognition-notice',
    article: 'Article 50(3)',
    name: 'Emotion Recognition',
    accent: 'Notice',
    blurb: 'Inform people exposed to emotion-recognition or biometric-categorisation systems.',
  },
  {
    href: '/patterns/human-review-gate',
    article: 'The accountable layer',
    name: 'Human Review',
    accent: 'Gate',
    blurb: 'Hold an AI-proposed action until a named human approves, edits, or rejects it.',
  },
];

const install = `# clone and run
git clone https://github.com/…/article50-kit
cd article50-kit
npm install
npm run dev

# or copy a single component from src/components/kit/`;
---

<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="mx-auto grid max-w-5xl items-center gap-10 px-6 pt-20 pb-16 md:grid-cols-[1.35fr_1fr]">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-muted" data-reveal>
          EU AI Act · Article 50 · enforceable 2 August 2026
        </p>
        <h1
          class="mt-4 font-display text-5xl font-semibold leading-[1.02] text-ink md:text-7xl"
          data-reveal
          style="--d:.07s"
        >
          Transparency, built into the <em class="italic text-orange">interface</em>.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted" data-reveal style="--d:.14s">
          Four accessible React components for the parts of the EU AI Act that live in the UI — AI
          disclosure, content labelling, emotion-recognition notice, and a human-in-the-loop review gate.
          WCAG 2.1 AA. MIT licensed.
        </p>
        <div class="mt-8 flex flex-wrap gap-3" data-reveal style="--d:.21s">
          <a
            href="#patterns"
            class="inline-flex items-center rounded-lg bg-ink px-5 py-2.5 text-sm font-semibold text-paper transition-colors hover:bg-orange"
          >
            Explore the patterns
          </a>
          <a
            href="https://github.com/"
            class="inline-flex items-center rounded-lg border border-line bg-paper px-5 py-2.5 text-sm font-semibold text-ink transition-colors hover:bg-surface"
          >
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Hero graphic: the human-in-the-loop network -->
      <div class="hidden md:block" data-reveal style="--d:.28s">
        <HeroNetwork />
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="border-y border-line bg-surface/40">
    <div class="mx-auto max-w-5xl px-6 py-12">
      <p class="measure text-lg leading-relaxed text-ink">
        Article 50 compliance is not a legal document — it is buttons, labels, notices, and review
        steps a person actually sees. These are the interface patterns, built to the accessibility
        standard the law itself points to, ready to drop into a React or Astro product.
      </p>
    </div>
  </section>

  <!-- PATTERNS — editorial contents index -->
  <section id="patterns" aria-labelledby="patterns-heading" class="mx-auto max-w-5xl px-6 py-16">
    <div class="flex items-baseline justify-between gap-4">
      <h2 id="patterns-heading" class="font-display text-3xl font-semibold text-ink">The patterns</h2>
      <span class="font-mono text-xs tabular-nums text-muted">Four components</span>
    </div>

    <ol class="mt-10 border-t border-line">
      {
        patterns.map((p, i) => (
          <li>
            <a
              href={p.href}
              class="group grid grid-cols-[auto_1fr_auto] items-baseline gap-x-6 border-b border-line py-7 transition-colors hover:bg-surface/50"
            >
              <span class="font-mono text-sm tabular-nums text-orange">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <h3 class="font-display text-2xl font-semibold text-ink">
                    {p.name} <em class="italic text-orange">{p.accent}</em>
                  </h3>
                  <span class="text-xs font-semibold uppercase tracking-[0.22em] text-muted">{p.article}</span>
                </div>
                <p class="mt-2 max-w-xl text-muted">{p.blurb}</p>
              </div>
              <span
                class="text-lg text-muted transition-all group-hover:translate-x-1 group-hover:text-orange"
                aria-hidden="true"
              >
                →
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- INSTALL -->
  <section aria-labelledby="install-heading" class="mx-auto max-w-5xl px-6 pb-8">
    <h2 id="install-heading" class="font-display text-3xl font-semibold text-ink">Get started</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <pre class="code">{install}</pre>
      <div class="text-ink">
        <p class="leading-relaxed">
          Built with Astro, React, and Tailwind — the same stack the components target. Each component is
          a single self-contained file under <code>src/components/kit/</code>, so you can copy one in or use
          the set.
        </p>
        <p class="mt-4 leading-relaxed text-muted">
          These are engineering patterns, not legal advice. They help you meet Article 50 duties in the
          interface; confirm your specific obligations with qualified counsel.
        </p>
      </div>
    </div>
  </section>
</Base>
