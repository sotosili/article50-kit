---
import Base from './Base.astro';

interface Props {
  /** Article 50 reference, e.g. "Article 50(1)". */
  article: string;
  /** Heading, split so the accent word renders in Playfair italic orange. */
  name: string;
  accent: string;
  intro: string;
  title?: string;
}
const { article, name, accent, intro, title } = Astro.props;
---

<Base title={title ?? `${name} ${accent} — Article 50 Kit`} description={intro}>
  <article class="mx-auto max-w-5xl px-6 pt-14">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-orange">{article}</p>
    <h1 class="mt-3 font-display text-5xl font-semibold leading-[1.05] text-ink md:text-6xl">
      {name} <em class="italic text-orange">{accent}</em>
    </h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">{intro}</p>

    <div class="mt-12 flex flex-col gap-12">
      <slot />
    </div>
  </article>
</Base>
