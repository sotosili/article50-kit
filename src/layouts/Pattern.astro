---
import Base from './Base.astro';

interface Props {
  /** Article 50 reference, e.g. "Article 50(1)". */
  article: string;
  /** Heading, split so the accent word renders in Playfair italic orange. */
  name: string;
  accent: string;
  intro: string;
  /** Plain-language statement of the legal duty - shown as an editorial margin note. */
  duty: string;
  /** Two-digit pattern number, e.g. "01". */
  index: string;
  title?: string;
}
const { article, name, accent, intro, duty, index, title } = Astro.props;
---

<Base title={title ?? `${name} ${accent} - Article 50 Kit`} description={intro}>
  <article class="mx-auto max-w-5xl px-6 pt-16">
    <div class="flex items-center gap-4" data-reveal>
      <span class="font-mono text-xs tabular-nums text-flame">PATTERN {index} / 04</span>
      <span class="h-px flex-1 bg-line"></span>
      <span class="text-xs font-semibold uppercase tracking-[0.28em] text-muted">{article}</span>
    </div>

    <h1
      class="mt-7 font-display text-5xl font-semibold leading-[1.03] text-ink md:text-7xl"
      data-reveal
      style="--d:.06s"
    >
      {name} <em class="italic text-ember">{accent}</em>
    </h1>

    <div class="mt-8 grid gap-8 md:grid-cols-[1fr_15rem] md:items-start">
      <p class="measure text-lg leading-relaxed text-muted" data-reveal style="--d:.12s">{intro}</p>
      <aside class="border-t border-ink pt-3" data-reveal style="--d:.18s">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-muted">The duty</p>
        <p class="mt-2 text-sm leading-relaxed text-ink">{duty}</p>
      </aside>
    </div>

    <div class="mt-16 flex flex-col gap-16">
      <slot />
    </div>
  </article>
</Base>
