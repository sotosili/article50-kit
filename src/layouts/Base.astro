---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Article 50 UI Pattern Kit',
  description = 'Accessible, WCAG 2.1 AA React components for EU AI Act Article 50 transparency.',
} = Astro.props;

const nav = [
  { href: '/patterns/ai-disclosure-badge', label: 'AI disclosure' },
  { href: '/patterns/ai-content-label', label: 'Content label' },
  { href: '/patterns/emotion-recognition-notice', label: 'Emotion notice' },
  { href: '/patterns/human-review-gate', label: 'Review gate' },
];
const path = Astro.url.pathname.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://article50-kit.pages.dev/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://article50-kit.pages.dev/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://article50-kit.pages.dev/og.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Playfair+Display:ital,wght@0,500;0,600;1,500;1,600&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data: an open-source software kit + its author -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareSourceCode',
      name: 'Article 50 UI Pattern Kit',
      description:
        'Accessible, WCAG 2.1 AA React components for EU AI Act Article 50 transparency: AI disclosure, content labelling, an emotion-recognition notice, and a human-in-the-loop review gate.',
      url: 'https://article50-kit.pages.dev/',
      codeRepository: 'https://github.com/sotosili/article50-kit',
      programmingLanguage: ['TypeScript', 'React', 'Astro'],
      license: 'https://opensource.org/licenses/MIT',
      keywords: 'EU AI Act, Article 50, AI transparency, accessibility, WCAG, React, design engineering, responsible AI',
      author: {
        '@type': 'Person',
        name: 'Sotiris Iliadis',
        jobTitle: 'Product Designer & Design Engineer',
        url: 'https://sotiris-portfolio.pages.dev',
        sameAs: ['https://github.com/sotosili', 'https://www.linkedin.com/in/sotiris-iliadis'],
      },
    })} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="border-b border-line">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-6 py-4">
        <a href="/" class="font-display text-lg font-semibold text-ink">
          Article 50 <span class="italic text-flame">Kit</span>
        </a>
        <nav aria-label="Patterns" class="flex flex-wrap items-center gap-1 text-sm">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={path === item.href ? 'page' : undefined}
                class:list={[
                  'rounded-md px-3 py-1.5 font-medium transition-colors hover:bg-surface',
                  path === item.href ? 'bg-surface text-ink' : 'text-muted',
                ]}
              >
                {item.label}
              </a>
            ))
          }
          <a
            href="/demo"
            aria-current={path === '/demo' ? 'page' : undefined}
            class:list={[
              'rounded-md px-3 py-1.5 font-medium transition-colors hover:bg-surface',
              path === '/demo' ? 'bg-surface text-ink' : 'text-flame',
            ]}
          >
            Live demo
          </a>
          <a
            href="https://github.com/sotosili/article50-kit"
            class="ml-1 rounded-md border border-line px-3 py-1.5 font-medium text-ink transition-colors hover:bg-surface"
          >
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-24 border-t border-line">
      <div class="mx-auto max-w-5xl px-6 py-10 text-sm text-muted">
        <p>
          Article 50 UI Pattern Kit — built by
          <a href="https://sotiris-portfolio.pages.dev" class="font-medium text-ink underline underline-offset-2">Sotiris Iliadis</a>.
          MIT licensed. WCAG 2.1 AA.
        </p>
        <p class="mt-2 max-w-2xl">
          These components help you meet EU AI Act Article 50 transparency duties in the interface. They
          are engineering patterns, not legal advice — confirm your obligations with qualified counsel.
        </p>
      </div>
    </footer>
  </body>
</html>
